{
  "name": "piggybet",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "dev:all": "concurrently -n \"🏢API,🎮PLAYER,⚙️ADMIN\" -c \"green,cyan,yellow\" \"npm run dev:backend\" \"npm run dev:player\" \"npm run dev:admin\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:admin": "cd back-office && npx vite --port 3002 --host",
    "db:migrate": "cd backend && npx prisma migrate deploy",
    "db:generate": "cd backend && npx prisma generate",
    "db:push": "cd backend && npx prisma db push",
    "expire-deposits": "node scripts/expire-pending-deposits.js",
    "worker:expire": "node scripts/worker/expire-deposits.js"
  },
  "dependencies": {
    "@heroicons/react": "^2.1.0",
    "@hookform/resolvers": "^3.6.0",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@tanstack/react-query": "^5.45.0",
    "@tanstack/react-table": "^8.17.3",
    "axios": "^1.7.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.11",
    "embla-carousel-react": "^8.1.5",
    "framer-motion": "^11.0.0",
    "gsap": "^3.12.5",
    "lucide-react": "^0.400.0",
    "next": "15.0.0",
    "next-themes": "^0.3.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-hook-form": "^7.52.0",
    "react-icons": "^5.2.1",
    "react-loading-skeleton": "^3.4.0",
    "react-virtuoso": "^4.9.0",
    "recharts": "^2.12.7",
    "sharp": "^0.33.4",
    "sonner": "^1.5.0",
    "swiper": "^11.1.5",
    "tailwind-merge": "^2.3.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "concurrently": "^10.0.3",
    "eslint": "^8.0.0",
    "eslint-config-next": "15.0.0",
    "postcss": "^8.0.0",
    "tailwindcss": "^3.0.0",
    "typescript": "^5.0.0"
  }
}