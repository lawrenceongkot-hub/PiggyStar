{
  "name": "piggybet",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "dev:all": "concurrently -n \"🏢API,🎮PLAYER,⚙️ADMIN\" -c \"green,cyan,yellow\" \"npm run dev:backend\" \"npm run dev:player\" \"npm run dev:admin\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:admin": "cd back-office && npx vite --port 3002 --host",
    "db:migrate": "cd backend && npx prisma migrate deploy",
    "db:generate": "cd backend && npx prisma generate",
    "db:push": "cd backend && npx prisma db push",
    "expire-deposits": "node scripts/expire-pending-deposits.js",
    "worker:expire": "node scripts/worker/expire-deposits.js"
  },
  "dependencies": {
    "next": "15.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "concurrently": "^10.0.3",
    "eslint": "^8.0.0",
    "eslint-config-next": "15.0.0",
    "typescript": "^5.0.0"
  }
}