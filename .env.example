# ===== Required Environment Variables =====
# Copy this file to .env and fill in the values

# Database (PostgreSQL for staging/production)
DATABASE_URL="postgresql://user:password@localhost:5432/piggybet?schema=public"

# Redis (for queues and sessions)
REDIS_URL="redis://:password@localhost:6379"

# Security
SESSION_SECRET="generate-a-random-64-char-string"
JWT_SECRET="piggyStar_dev_secret_change_this"
ADMIN_API_KEY="generate-a-random-api-key"

# URLs
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:4000"
PLAYER_APP_URL="http://localhost:3000"
ADMIN_APP_URL="http://localhost:3001"
BACKEND_URL="http://localhost:4000"
BACKOFFICE_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:3000"

# OTP (set to false in staging/production)
OTP_MANUAL_MODE="true"
EMAIL_MANUAL_MODE="true"

# ===== Wave Unified Game API =====
# Leave empty until API key is provided
WAVE_API_BASE_URL="https://api.wavewl.tech"
WAVE_API_KEY=""
WAVE_RETURN_URL="/lobby"
WAVE_DEFAULT_LANGUAGE="en"
WAVE_TIMEOUT="30000"
WAVE_USE_SANDBOX="true"
WAVE_SESSION_TIMEOUT="3600"
WAVE_WEBHOOK_SECRET=""

# Moxsys Payment Gateway (optional - leave commented if not used)
# MOXSYS_API_KEY="your-production-api-key"
# MOXSYS_MODE="live"
# MOXSYS_BASE_URL="https://platform.moxsys.io/api"
# MOXSYS_CALLBACK_URL="https://staging.example.com/api/payment/moxsys/webhook"

# SMTP (for email OTP)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@example.com"
# SMTP_PASS="your-email-password"

# Telegram (for Telegram OTP)
# TELEGRAM_BOT_TOKEN="your-bot-token"
# TELEGRAM_CHAT_ID="your-chat-id"

# SMS (for SMS OTP)
# SMS_API_URL="https://sms-provider-api.com/send"
# SMS_API_KEY="your-sms-api-key"
# SMS_SENDER_NAME="YourBrand"