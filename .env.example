# ===== Required Environment Variables =====
# Copy this file to .env and fill in the values

# Database (PostgreSQL for staging/production)
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Redis (for queues and sessions)
REDIS_URL="redis://:password@host:6379"

# Security
SESSION_SECRET="generate-a-random-64-char-string"
JWT_SECRET="generate-another-random-64-char-string"
ADMIN_API_KEY="generate-a-random-api-key"

# URLs
NEXT_PUBLIC_SITE_URL="https://staging.example.com"
FRONTEND_URL="https://staging.example.com"
BACKEND_URL="https://staging.example.com"
BACKOFFICE_URL="https://admin.staging.example.com"

# OTP (set to false in staging/production)
OTP_MANUAL_MODE="false"
EMAIL_MANUAL_MODE="false"

# Moxsys Payment Gateway (optional - leave commented if not used)
# MOXSYS_API_KEY="your-production-api-key"
# MOXSYS_MODE="live"
# MOXSYS_BASE_URL="https://platform.moxsys.io/api"
# MOXSYS_CALLBACK_URL="https://staging.example.com/api/payment/moxsys/webhook"

# SMTP (for email OTP)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@example.com"
# SMTP_PASS="your-email-password"

# Telegram (for Telegram OTP)
# TELEGRAM_BOT_TOKEN="your-bot-token"
# TELEGRAM_CHAT_ID="your-chat-id"

# SMS (for SMS OTP)
# SMS_API_URL="https://sms-provider-api.com/send"
# SMS_API_KEY="your-sms-api-key"
# SMS_SENDER_NAME="YourBrand"